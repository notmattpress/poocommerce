{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "poocommerce/add-to-wishlist-button",
	"version": "1.0.0",
	"title": "Add to Wishlist Button",
	"description": "Lets shoppers add the current product to their wishlist from the single-product page.",
	"category": "poocommerce",
	"keywords": [ "PooCommerce", "Wishlist" ],
	"textdomain": "poocommerce",
	"usesContext": [ "postId" ],
	"ancestor": [ "poocommerce/add-to-cart-with-options" ],
	"supports": {
		"interactivity": true,
		"html": false,
		"reusable": false,
		"multiple": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		},
		"color": {
			"text": true,
			"background": true
		}
	},
	"viewScriptModule": "poocommerce/add-to-wishlist-button",
	"style": [ "file:../poocommerce/add-to-wishlist-button-style.css" ]
}
