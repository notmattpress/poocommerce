{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "poocommerce/dropdown",
	"title": "Dropdown",
	"description": "Display options in a dropdown.",
	"category": "poocommerce",
	"keywords": [ "PooCommerce" ],
	"textdomain": "poocommerce",
	"apiVersion": 3,
	"ancestor": [
		"poocommerce/add-to-cart-with-options-variation-selector-attribute"
	],
	"supports": {
		"interactivity": true,
		"poocommerce": {
			"innerBlockDisplayStyle": true
		}
	},
	"usesContext": [ "poocommerce/selectableItems", "poocommerce/attributeId" ],
	"attributes": {},
	"viewScriptModule": "poocommerce/dropdown",
	"style": "file:../poocommerce/dropdown-style.css",
	"editorStyle": "file:../poocommerce/dropdown-editor.css"
}
