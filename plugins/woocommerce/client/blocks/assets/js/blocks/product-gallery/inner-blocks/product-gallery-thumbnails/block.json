{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "poocommerce/product-gallery-thumbnails",
	"version": "1.0.0",
	"title": "Thumbnails",
	"description": "Display the Thumbnails of a product.",
	"category": "poocommerce",
	"keywords": [ "PooCommerce" ],
	"usesContext": [ "postId", "cropImages" ],
	"textdomain": "poocommerce",
	"ancestor": [ "poocommerce/product-gallery" ],
	"attributes": {
		"thumbnailSize": {
			"type": "string",
			"default": "33%"
		}
	},
	"supports": {
		"spacing": {
			"margin": true
		}
	}
}
