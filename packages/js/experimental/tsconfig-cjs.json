{
	"extends": "@woocommerce/internal-ts-config/tsconfig-cjs.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "build",
		"typeRoots": [
			"./typings",
			"./node_modules/@types"
		]
	},
	"include": [
		"typings/**/*",
		"src/**/*"
	],
	"exclude": [
		"**/test/**",
		"**/stories/**"
	]
}
