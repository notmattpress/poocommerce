{
	"extends": "@woocommerce/internal-ts-config/tsconfig.json",
	"compilerOptions": {
		"rootDir": "src",
		"noCheck": false,
		"outDir": "build-module",
		"declaration": true,
		"declarationMap": true,
		"declarationDir": "./build-types",
		"resolveJsonModule": true,
		"typeRoots": [
			"./typings",
			"./node_modules/@types"
		],
		"composite": true
	},
	"include": [
		"typings/**/*",
		"src/**/*",
		"src/**/*.json"
	],
	"exclude": [
		"**/test/**",
		"**/stories/**"
	],
	"references": [
		{
			"path": "../admin-layout"
		},
		{
			"path": "../block-templates"
		},
		{
			"path": "../components"
		},
		{
			"path": "../currency"
		},
		{
			"path": "../customer-effort-score"
		},
		{
			"path": "../data"
		},
		{
			"path": "../experimental"
		},
		{
			"path": "../expression-evaluation"
		},
		{
			"path": "../navigation"
		},
		{
			"path": "../number"
		},
		{
			"path": "../sanitize"
		},
		{
			"path": "../tracks"
		}
	]
}
